{
  "rewrites": [
    {
      "source": "/api/neon-auth/:path*",
      "destination": "/api/neon-auth-proxy?_subpath=:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index?_path=:path*"
    },
    {
      "source": "/((?!api|_next|favicon|icon|manifest|assets|og-image|apple-touch-icon).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
